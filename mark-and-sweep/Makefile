# Makefile for Pulse GC (Mark-and-Sweep)
#
# Verifies and extracts the sequential stop-the-world garbage collector.
# Dependencies auto-generated by `fstar.exe --dep full` (see .depend target).
# Shared infrastructure (Heap, Object, Stack) lives in ../common/.

FSTAR_HOME ?= $(CURDIR)/../FStar
FSTAR      ?= $(FSTAR_HOME)/bin/fstar.exe
KRML_HOME  ?= $(FSTAR_HOME)/karamel
KRML       ?= $(KRML_HOME)/krml

C = ../common

# --- Include paths ----------------------------------------------------------

COMMON_INCLUDES = --include spec --include $(C)/spec --include $(C)/lib

PULSE_LIB ?= $(FSTAR_HOME)/pulse/lib/pulse/lib

SPEC_INCLUDES = $(COMMON_INCLUDES)
IMPL_INCLUDES = $(COMMON_INCLUDES) --include impl --include $(C)/impl --include $(PULSE_LIB)

# --- F* flags ---------------------------------------------------------------

FSTAR_BASE = --cache_checked_modules --warn_error -321 --report_assumes warn

FSTAR_SPEC_FLAGS = $(FSTAR_BASE) $(SPEC_INCLUDES) --already_cached 'FStar -GC'
FSTAR_IMPL_FLAGS = $(FSTAR_BASE) $(IMPL_INCLUDES) --split_queries always \
  --already_cached 'FStar Pulse -GC'

# --- Sources ----------------------------------------------------------------

SPEC_SRC = $(wildcard spec/*.fst spec/*.fsti)
IMPL_SRC = $(wildcard impl/*.fst impl/*.fsti)
ALL_SRC  = $(SPEC_SRC) $(IMPL_SRC)

SPEC_CHECKED = $(addsuffix .checked,$(SPEC_SRC))
IMPL_CHECKED = $(addsuffix .checked,$(IMPL_SRC))

# --- Phony targets ----------------------------------------------------------

.PHONY: all verify verify-spec verify-impl extract snapshot clean

all: verify

verify: verify-impl

verify-spec: $(SPEC_CHECKED)
	@echo "=== mark-and-sweep: spec modules verified ==="

verify-impl: verify-spec $(IMPL_CHECKED)
	@echo "=== mark-and-sweep: impl modules verified ==="

# --- Common/ build (delegate to common/Makefile via stamps) -----------------

COMMON_SPEC_SRC  = $(wildcard $(C)/spec/*.fst $(C)/spec/*.fsti $(C)/lib/*.fst)
COMMON_IMPL_SRC  = $(wildcard $(C)/impl/*.fst $(C)/impl/*.fsti)

.common-stamp: $(COMMON_SPEC_SRC)
	+$(MAKE) -C $(C)
	@touch $@

.common-impl-stamp: .common-stamp $(COMMON_IMPL_SRC)
	+$(MAKE) -C $(C) verify-impl
	@touch $@

# Common checked files are produced by common/Makefile; order-only on stamps.
$(C)/spec/%.checked $(C)/lib/%.checked: | .common-stamp ;
$(C)/impl/%.checked:                    | .common-impl-stamp ;

# --- Auto-generated dependency graph ----------------------------------------
#
# `fstar.exe --dep full` emits Make rules for every transitive dependency.
# We post-process to keep only rules whose targets are local (spec/ or impl/),
# stripping absolute-path prerequisites (FStar/Pulse libraries that are
# --already_cached and always present).  Common/ prereqs are retained so
# that the stamps are triggered.

.depend: $(ALL_SRC) | .common-impl-stamp
	$(FSTAR) $(FSTAR_BASE) $(IMPL_INCLUDES) \
	  --already_cached 'FStar Pulse' \
	  --dep full $(ALL_SRC) \
	  --output_deps_to $@.raw
	@awk -v cwd="$$(pwd)/" -v proj="$$(cd .. && pwd)/" '\
	  { gsub(cwd, ""); gsub(proj, "../") } \
	  /^[^[:space:]].*:/ { if (p) flush(); \
	    p = (/^(spec|impl)\/.*\.checked:/) ? 1 : 0; n = 0 } \
	  p { line = $$0; \
	      tmp = line; gsub(/^[ \t]+/, "", tmp); gsub(/[ \t]*\\?[ \t]*$$/, "", tmp); \
	      if (tmp == "") next; \
	      if (tmp !~ /^(spec|impl)\/|^\.\.\/common\// && tmp !~ /:/) next; \
	      buf[n++] = line } \
	  END { if (p) flush() } \
	  function flush() { if (n==0) return; \
	    sub(/[ \t]*\\[ \t]*$$/, "", buf[n-1]); \
	    for (i=0;i<n;i++) print buf[i]; print ""; n=0 }' $@.raw > $@
	@rm -f $@.raw

-include .depend

# --- Pattern rules (verification recipes) -----------------------------------

spec/%.checked: spec/%
	$(FSTAR) $(FSTAR_SPEC_FLAGS) $<

impl/%.checked: impl/%
	$(FSTAR) $(FSTAR_IMPL_FLAGS) --z3refresh $<

# --- Extraction to C via KaRaMeL -------------------------------------------
#
# Phase 1: fstar.exe --codegen krml  → .krml  (one per module)
# Phase 2: krml .krml → GC_Impl.c/.h          (bundle into single C file)

KRML_OUTPUT_DIR = _output
EXTRACT_DIR     = _extract

FSTAR_EXTRACT_FLAGS = $(FSTAR_BASE) --split_queries always \
  --already_cached 'FStar Pulse -GC'

KRML_FLAGS = \
  -tmpdir $(EXTRACT_DIR) \
  -skip-compilation -skip-linking \
  -bundle 'GC.Impl=GC.Impl.*' \
  -bundle 'FStar.Pervasives.Native' \
  -bundle 'GC.Spec.*,GC.Lib.Header,GC.Lib.Address' \
  -no-prefix GC.Impl \
  -no-prefix GC.Impl.Mark \
  -no-prefix GC.Impl.Sweep \
  -no-prefix GC.Impl.Fields \
  -no-prefix GC.Impl.Closure \
  -no-prefix GC.Impl.Heap \
  -no-prefix GC.Impl.Object \
  -no-prefix GC.Impl.Stack \
  -warn-error -2-9-15

# Modules to extract
MS_MODULES     = GC.Impl.Fields GC.Impl.Closure GC.Impl.Mark GC.Impl.Sweep GC.Impl
COMMON_MODULES = GC.Impl.Heap GC.Impl.Object GC.Impl.Stack
DEP_SPEC_MODULES = GC.Spec.Base GC.Spec.Heap GC.Spec.Object
DEP_LIB_MODULES  = GC.Lib.Header GC.Lib.Address

# Derive .krml paths from module names  (GC.Impl.Mark → _output/GC_Impl_Mark.krml)
mod_to_krml = $(patsubst %,$(KRML_OUTPUT_DIR)/%.krml,$(subst .,_,$(1)))

MS_KRML     = $(call mod_to_krml,$(MS_MODULES))
COMMON_KRML = $(call mod_to_krml,$(COMMON_MODULES))
DEP_KRML    = $(call mod_to_krml,$(DEP_SPEC_MODULES)) \
              $(call mod_to_krml,$(DEP_LIB_MODULES)) \
              $(KRML_OUTPUT_DIR)/FStar_Pervasives_Native.krml
ALL_KRML    = $(MS_KRML) $(COMMON_KRML) $(DEP_KRML)

$(KRML_OUTPUT_DIR) $(EXTRACT_DIR):
	@mkdir -p $@

# Generic .krml extraction rule for mark-and-sweep impl modules
define ms_krml_rule
$(call mod_to_krml,$(1)): impl/$(1).fst | $(KRML_OUTPUT_DIR)
	$$(FSTAR) $$(IMPL_INCLUDES) $$(FSTAR_EXTRACT_FLAGS) \
	  --codegen krml --extract_module $(1) --odir $$(KRML_OUTPUT_DIR) $$<
endef
$(foreach m,$(MS_MODULES),$(eval $(call ms_krml_rule,$(m))))

# Generic .krml extraction rule for common/ impl modules
define common_krml_rule
$(call mod_to_krml,$(1)): $(C)/impl/$(1).fst | $(KRML_OUTPUT_DIR)
	$$(FSTAR) $$(IMPL_INCLUDES) $$(FSTAR_EXTRACT_FLAGS) \
	  --codegen krml --extract_module $(1) --odir $$(KRML_OUTPUT_DIR) $$<
endef
$(foreach m,$(COMMON_MODULES),$(eval $(call common_krml_rule,$(m))))

# Generic .krml extraction rule for dependency spec modules
define dep_spec_krml_rule
$(call mod_to_krml,$(1)): $(C)/spec/$(1).fst | $(KRML_OUTPUT_DIR)
	$$(FSTAR) $$(COMMON_INCLUDES) $$(FSTAR_BASE) --already_cached 'FStar -GC' \
	  --codegen krml --extract_module $(1) --odir $$(KRML_OUTPUT_DIR) $$<
endef
$(foreach m,$(DEP_SPEC_MODULES),$(eval $(call dep_spec_krml_rule,$(m))))

# Generic .krml extraction rule for dependency lib modules
define dep_lib_krml_rule
$(call mod_to_krml,$(1)): $(C)/lib/$(1).fst | $(KRML_OUTPUT_DIR)
	$$(FSTAR) $$(COMMON_INCLUDES) $$(FSTAR_BASE) --already_cached 'FStar -GC' \
	  --codegen krml --extract_module $(1) --odir $$(KRML_OUTPUT_DIR) $$<
endef
$(foreach m,$(DEP_LIB_MODULES),$(eval $(call dep_lib_krml_rule,$(m))))

$(KRML_OUTPUT_DIR)/FStar_Pervasives_Native.krml: | $(KRML_OUTPUT_DIR)
	$(FSTAR) --cache_checked_modules --warn_error -321 \
	  --codegen krml --extract_module FStar.Pervasives.Native \
	  --odir $(KRML_OUTPUT_DIR) $(FSTAR_HOME)/ulib/FStar.Pervasives.Native.fst

# Phase 2: bundle .krml → C
$(EXTRACT_DIR)/GC_Impl.c: $(ALL_KRML) | $(EXTRACT_DIR)
	$(KRML) $(KRML_FLAGS) $(ALL_KRML)

extract: verify-impl $(EXTRACT_DIR)/GC_Impl.c
	@echo "=== Extraction complete: $(EXTRACT_DIR)/GC_Impl.{c,h} ==="

# --- Snapshot ---------------------------------------------------------------

SNAPSHOT_DIR = snapshot

snapshot: extract
	@echo "=== Creating snapshot ==="
	@mkdir -p $(SNAPSHOT_DIR)/krmllib/krml/internal $(SNAPSHOT_DIR)/internal
	@rm -f $(SNAPSHOT_DIR)/internal/*.h
	@cp $(EXTRACT_DIR)/GC_Impl.c $(SNAPSHOT_DIR)/
	@cp $(EXTRACT_DIR)/GC_Impl.h $(SNAPSHOT_DIR)/
	@cp $(EXTRACT_DIR)/GC_Spec_GC_Lib_Header_GC_Lib_Address.h $(SNAPSHOT_DIR)/ 2>/dev/null || true
	@cp $(EXTRACT_DIR)/internal/*.h $(SNAPSHOT_DIR)/internal/ 2>/dev/null || true
	@cp $(KRML_HOME)/include/krmllib.h $(SNAPSHOT_DIR)/krmllib/ 2>/dev/null || true
	@cp -r $(KRML_HOME)/krmllib/dist/minimal/* $(SNAPSHOT_DIR)/krmllib/ 2>/dev/null || true
	@cp $(KRML_HOME)/include/krml/*.h $(SNAPSHOT_DIR)/krmllib/krml/ 2>/dev/null || true
	@cp $(KRML_HOME)/include/krml/internal/*.h $(SNAPSHOT_DIR)/krmllib/krml/internal/ 2>/dev/null || true
	@if ! grep -q '^#include "pulsegc_compat.h"' $(SNAPSHOT_DIR)/GC_Impl.c 2>/dev/null; then \
	  sed -i '/#include "internal\/GC_Spec_GC_Lib_Header_GC_Lib_Address.h"/a #include "pulsegc_compat.h"' $(SNAPSHOT_DIR)/GC_Impl.c; \
	fi
	@echo "=== Snapshot updated: $(SNAPSHOT_DIR)/ ==="
	@echo "    Hand-maintained: pulsegc_compat.h, pulsegc_runtime.c, Makefile"

# --- Cleanup ----------------------------------------------------------------

clean:
	rm -f spec/*.checked* impl/*.checked*
	rm -f .depend .depend.raw .common-stamp .common-impl-stamp
	rm -rf $(KRML_OUTPUT_DIR) $(EXTRACT_DIR)
