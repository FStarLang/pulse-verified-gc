# Makefile for Pulse GC (Mark-and-Sweep)
#
# Single incremental build covering common/ + mark-and-sweep/ modules.
# All dependencies auto-generated by `fstar.exe --dep full`.
# Run `make -j8` for parallel verification.

FSTAR_HOME ?= $(CURDIR)/../FStar
FSTAR_EXE  ?= $(FSTAR_HOME)/bin/fstar.exe
KRML_HOME  ?= $(FSTAR_HOME)/karamel
KRML       ?= $(KRML_HOME)/krml

C = ../common
OUTPUT_DIR  = _output
EXTRACT_DIR = _extract

# --- F* flags ---------------------------------------------------------------

PULSE_LIB ?= $(FSTAR_HOME)/pulse/lib/pulse/lib

FSTAR_FLAGS = \
  --cache_checked_modules \
  --odir $(OUTPUT_DIR) \
  --warn_error -321 \
  --report_assumes warn \
  --already_cached 'Prims FStar Pulse PulseCore -GC' \
  --include spec --include impl \
  --include $(C)/spec --include $(C)/lib --include $(C)/impl \
  --include $(PULSE_LIB)

FSTAR = $(FSTAR_EXE) $(FSTAR_FLAGS)

# --- Sources ----------------------------------------------------------------

SPEC_SRC = $(wildcard spec/*.fst spec/*.fsti \
                      $(C)/spec/*.fst $(C)/spec/*.fsti $(C)/lib/*.fst)
IMPL_SRC = $(wildcard impl/*.fst impl/*.fsti \
                      $(C)/impl/*.fst $(C)/impl/*.fsti)
ALL_SRC  = $(SPEC_SRC) $(IMPL_SRC)

# --- Auto-generated dependency graph ----------------------------------------
#
# `fstar.exe --dep full` emits .checked and .krml rules.
# --already_cached ensures .checked targets are GC-only; awk post-processes
# to (a) normalize absolute paths and (b) filter .krml rules to GC modules.

.depend: $(ALL_SRC)
	$(FSTAR) --dep full $(ALL_SRC) --output_deps_to $@.raw
	@awk -v cwd="$$(pwd)/" -v proj="$$(cd .. && pwd)/" ' \
	  { gsub(cwd, ""); gsub(proj, "../") } \
	  /^[^ \t].*[:=]/ { if (n) flush(); \
	    keep = (/\.checked:/ || /^_output\/GC_.*\.krml:/ || /^ALL_CHECKED_FILES/) ? 1 : 0; n = 0 } \
	  keep { line = $$0; sub(/^[ \t]+/, "", line); sub(/[ \t]*\\?[ \t]*$$/, "", line); \
	    if (line == "") next; \
	    if (line !~ /[:=]/ && line !~ /^(spec|impl|_output)\/|^\.\.\/common\//) next; \
	    buf[n++] = $$0 } \
	  END { if (n) flush() } \
	  function flush() { if (!n) return; \
	    sub(/[ \t]*\\[ \t]*$$/, "", buf[n-1]); \
	    for (i=0;i<n;i++) print buf[i]; print ""; n=0 }' $@.raw > $@
	@rm -f $@.raw

-include .depend

# --- Phony targets ----------------------------------------------------------

.PHONY: all verify verify-spec verify-impl extract snapshot clean

all: verify

verify: verify-impl

verify-spec: $(addsuffix .checked,$(SPEC_SRC))
	@echo "=== spec modules verified ==="

verify-impl: $(ALL_CHECKED_FILES)
	@echo "=== all modules verified ==="

# --- Pattern rules (verification) -------------------------------------------

spec/%.checked: spec/%
	$(FSTAR) $<

$(C)/spec/%.checked: $(C)/spec/%
	$(FSTAR) $<

$(C)/lib/%.checked: $(C)/lib/%
	$(FSTAR) $<

impl/%.checked: impl/%
	$(FSTAR) --split_queries always --z3refresh $<

$(C)/impl/%.checked: $(C)/impl/%
	$(FSTAR) --split_queries always $<

# --- Pattern rules (extraction to .krml) ------------------------------------
#
# --dep full generates: _output/GC_Impl_Fields.krml: impl/GC.Impl.Fields.fst.checked ...
# The first prerequisite ($<) is always the module's .fst.checked file.

$(OUTPUT_DIR):
	@mkdir -p $@

_output/%.krml: | $(OUTPUT_DIR)
	$(FSTAR) --codegen krml \
	  --extract_module $(subst _,.,$*) \
	  $(patsubst %.checked,%,$(firstword $^))

# FStar.Pervasives.Native is needed for tuple extraction
_output/FStar_Pervasives_Native.krml: | $(OUTPUT_DIR)
	$(FSTAR_EXE) --cache_checked_modules --warn_error -321 \
	  --codegen krml --extract_module FStar.Pervasives.Native \
	  --odir $(OUTPUT_DIR) $(FSTAR_HOME)/ulib/FStar.Pervasives.Native.fst

# --- KaRaMeL bundling (.krml → C) ------------------------------------------

EXTRACT_MODULES = \
  GC.Impl.Fields GC.Impl.Closure GC.Impl.Mark GC.Impl.Sweep GC.Impl \
  GC.Impl.Heap GC.Impl.Object GC.Impl.Stack \
  GC.Spec.Base GC.Spec.Heap GC.Spec.Object GC.Lib.Header GC.Lib.Address

ALL_KRML = $(patsubst %,$(OUTPUT_DIR)/%.krml,$(subst .,_,$(EXTRACT_MODULES))) \
           $(OUTPUT_DIR)/FStar_Pervasives_Native.krml

KRML_FLAGS = \
  -tmpdir $(EXTRACT_DIR) \
  -skip-compilation -skip-linking \
  -bundle 'GC.Impl=GC.Impl.*' \
  -bundle 'FStar.Pervasives.Native' \
  -bundle 'GC.Spec.*,GC.Lib.Header,GC.Lib.Address' \
  $(patsubst %,-no-prefix %,GC.Impl GC.Impl.Mark GC.Impl.Sweep \
    GC.Impl.Fields GC.Impl.Closure GC.Impl.Heap GC.Impl.Object GC.Impl.Stack) \
  -warn-error -2-9-15

$(EXTRACT_DIR):
	@mkdir -p $@

$(EXTRACT_DIR)/GC_Impl.c: $(ALL_KRML) | $(EXTRACT_DIR)
	$(KRML) $(KRML_FLAGS) $(ALL_KRML)

extract: verify-impl $(EXTRACT_DIR)/GC_Impl.c
	@echo "=== Extraction complete: $(EXTRACT_DIR)/GC_Impl.{c,h} ==="

# --- Snapshot ---------------------------------------------------------------

SNAPSHOT_DIR = snapshot

snapshot: extract
	@echo "=== Creating snapshot ==="
	@mkdir -p $(SNAPSHOT_DIR)/krmllib/krml/internal $(SNAPSHOT_DIR)/internal
	@rm -f $(SNAPSHOT_DIR)/internal/*.h
	@cp $(EXTRACT_DIR)/GC_Impl.c $(SNAPSHOT_DIR)/
	@cp $(EXTRACT_DIR)/GC_Impl.h $(SNAPSHOT_DIR)/
	@cp $(EXTRACT_DIR)/GC_Spec_GC_Lib_Header_GC_Lib_Address.h $(SNAPSHOT_DIR)/ 2>/dev/null || true
	@cp $(EXTRACT_DIR)/internal/*.h $(SNAPSHOT_DIR)/internal/ 2>/dev/null || true
	@cp $(KRML_HOME)/include/krmllib.h $(SNAPSHOT_DIR)/krmllib/ 2>/dev/null || true
	@cp -r $(KRML_HOME)/krmllib/dist/minimal/* $(SNAPSHOT_DIR)/krmllib/ 2>/dev/null || true
	@cp $(KRML_HOME)/include/krml/*.h $(SNAPSHOT_DIR)/krmllib/krml/ 2>/dev/null || true
	@cp $(KRML_HOME)/include/krml/internal/*.h $(SNAPSHOT_DIR)/krmllib/krml/internal/ 2>/dev/null || true
	@echo "=== Snapshot updated ==="

# --- Cleanup ----------------------------------------------------------------

clean:
	rm -f spec/*.checked* impl/*.checked*
	rm -f $(C)/spec/*.checked* $(C)/lib/*.checked* $(C)/impl/*.checked*
	rm -f .depend .depend.raw
	rm -rf $(OUTPUT_DIR) $(EXTRACT_DIR)
