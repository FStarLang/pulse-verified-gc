# Makefile for Concurrent On-the-Fly GC (fly/)
#
# Dijkstra-style tri-color marking with shadow stacks.
# Uses F*'s --dep full for dependency tracking and incremental builds.
# Depends on common/ for shared infrastructure.

FSTAR ?= fstar.exe
PULSE_HOME ?= $(HOME)/pulse
KRML_HOME ?= $(shell opam var prefix)/lib/karamel

COMMON_DIR = ../common
COMMON_ABS = $(abspath $(COMMON_DIR))

# Include paths
FSTAR_INCLUDES = \
  --include $(COMMON_DIR)/Spec \
  --include $(COMMON_DIR)/Lib \
  --include $(PULSE_HOME)/out/lib/pulse \
  --include $(PULSE_HOME)/lib/pulse/lib \
  --include .

# F* options (fly-specific SMT tuning)
FSTAR_FLAGS = \
  --cache_checked_modules \
  --load_cmxs pulse \
  --warn_error -331 \
  --z3rlimit 100 \
  --max_fuel 2 \
  --max_ifuel 1 \
  --already_cached 'FStar Pulse -Pulse.Spec.GC -Pulse.Lib.GC -Pulse.Lib.Header -Pulse.Lib.Address'

# Source files (exclude test files with syntax errors from dep generation)
FST_FILES = $(wildcard Pulse.Spec.GC.*.fst Pulse.Lib.GC*.fst)

# Extraction
DIST_DIR = dist
LIB_FILES = \
  Pulse.Lib.GC.ConcurrentMark.fst \
  Pulse.Lib.GC.RootScanning.fst \
  Pulse.Lib.GC.Sweep.fst \
  Pulse.Lib.GC.fst

KRML_OPTIONS = \
  -bundle Pulse.Lib.GC=* \
  -bundle FStar.*,Pulse.* \
  -no-prefix Pulse.Lib.GC \
  -skip-compilation \
  -tmpdir $(DIST_DIR) \
  -add-include '"kremlib.h"' \
  -add-include '"prims.h"'

# ------------------------------------------------------------------------------
# Targets
# ------------------------------------------------------------------------------

.PHONY: all verify extract clean

all: verify

# .depend is generated by F*'s --dep full and defines ALL_CHECKED_FILES
.depend: $(FST_FILES)
	$(FSTAR) --dep full $(FSTAR_INCLUDES) $(FSTAR_FLAGS) $^ > $@

include .depend

# Filter out external (absolute-path) entries — only build local modules
LOCAL_CHECKED = $(filter-out /%, $(ALL_CHECKED_FILES))

# Verify local modules (common/ is built on demand via delegation rule)
verify: $(LOCAL_CHECKED)
	@echo "=== fly: all modules verified ==="

# Delegate common module builds to ../common/
$(COMMON_ABS)/%.checked:
	$(MAKE) -C $(COMMON_DIR)

# Pattern rules for incremental verification
%.fst.checked: %.fst
	$(FSTAR) $(FSTAR_INCLUDES) $(FSTAR_FLAGS) $<

%.fsti.checked: %.fsti
	$(FSTAR) $(FSTAR_INCLUDES) $(FSTAR_FLAGS) $<

# Extraction to C via KaRaMeL
extract: verify
	@echo "=== Extracting to C ==="
	@mkdir -p $(DIST_DIR)
	krml $(KRML_OPTIONS) \
		$(FSTAR_INCLUDES) \
		--admit_smt_queries true \
		$(LIB_FILES)
	@echo "=== Extraction complete: $(DIST_DIR)/ ==="

# Cleanup
clean:
	rm -f *.checked*
	rm -f .depend
	rm -rf $(DIST_DIR)
