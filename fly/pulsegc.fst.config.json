{
  "fstar_exe": "fstar.exe",
  "options": [
    "--cache_checked_modules",
    "--load_cmxs", "pulse",
    "--warn_error", "-331",
    "--z3rlimit", "100",
    "--max_fuel", "2",
    "--max_ifuel", "1",
    "--already_cached", "FStar Pulse -Pulse.Spec.GC -Pulse.Lib.GC -Pulse.Lib.Header -Pulse.Lib.Address"
  ],
  "include_dirs": [
    "../common/Spec",
    "../common/Lib",
    "${PULSE_HOME}/out/lib/pulse",
    "${PULSE_HOME}/lib/pulse/lib",
    "."
  ]
}
